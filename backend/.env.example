# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LinkedIn OAuth — from your LinkedIn Developer App
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Where LinkedIn redirects after login — must match your LinkedIn app's Authorized Redirect URLs
LINKEDIN_REDIRECT_URI=http://localhost:3001/auth/linkedin/callback

# Frontend URL (used for redirects after OAuth)
FRONTEND_URL=http://localhost:5173

# Secret for signing JWTs — make this long and random
JWT_SECRET=a

PORT=3001
